{
  "name": "swashbuckler",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@swashbuckler/web",
    "dev:all": "turbo run dev",
    "dev:docs": "turbo run dev --filter=@swashbuckler/docs",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test:run": "turbo run test:run",
    "test:e2e": "turbo run test:e2e"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1"
  }
}
